{
  "name": "longlive-docs-site",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "prepare": "node ./scripts/sync-docs.mjs",
    "dev": "node ./scripts/sync-docs.mjs && node ./node_modules/vitepress/dist/node/cli.js dev docs",
    "build": "node ./scripts/sync-docs.mjs && node ./node_modules/vitepress/dist/node/cli.js build docs",
    "preview": "node ./node_modules/vitepress/dist/node/cli.js preview docs",
    "docs:sync": "node ./scripts/sync-docs.mjs",
    "docs:dev": "node ./scripts/sync-docs.mjs && node ./node_modules/vitepress/dist/node/cli.js dev docs",
    "docs:build": "node ./scripts/sync-docs.mjs && node ./node_modules/vitepress/dist/node/cli.js build docs",
    "docs:preview": "node ./node_modules/vitepress/dist/node/cli.js preview docs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
